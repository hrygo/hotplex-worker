# HotPlex Worker Gateway - Environment Variables Example
#
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED SECRETS (MUST be set)
# ─────────────────────────────────────────────────────────────────────────────

# JWT secret for session token validation
# Generate: openssl rand -base64 32 | tr -d '\n'
HOTPLEX_JWT_SECRET=

# Admin API tokens (at least one required)
# Generate: openssl rand -base64 32 | tr -d '/+=' | head -c 43
HOTPLEX_ADMIN_TOKEN_1=
HOTPLEX_ADMIN_TOKEN_2=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL SECRETS
# ─────────────────────────────────────────────────────────────────────────────

# API keys for client authentication (comma-separated)
# HOTPLEX_API_KEYS=api_key_1,api_key_2

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL CONFIGURATION OVERRIDES
# ─────────────────────────────────────────────────────────────────────────────

# Log level: debug, info, warn, error (default: info)
# HOTPLEX_LOG_LEVEL=info

# Database path (default: hotplex-worker.db)
# HOTPLEX_DB_PATH=/var/lib/hotplex/data/hotplex-worker.db

# Gateway address (default: :8888)
# HOTPLEX_GATEWAY_ADDR=:8888

# Admin API address (default: :9999)
# HOTPLEX_ADMIN_ADDR=:9999

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────

# OpenTelemetry exporter endpoint (default: disabled)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Service name for traces (default: hotplex-worker-gateway)
# OTEL_SERVICE_NAME=hotplex-worker-gateway

# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT ONLY (DO NOT USE IN PRODUCTION)
# ─────────────────────────────────────────────────────────────────────────────

# Disable TLS for local development (default: false)
# HOTPLEX_TLS_ENABLED=false

# Allow all CORS origins (default: *)
# HOTPLEX_ALLOWED_ORIGINS=*
